    InitMatchList(&ML);\par
\par
    // creating initial players and adding them to the main queue F\par
    CreateInitialPlayers(&F, numPlayers);\par
    \par
    // Get initial players\par
    if (!IsEmpty(&F)) Dequeue(&F, &p1);\par
    if (!IsEmpty(&F)) Dequeue(&F, &p2);\par
    \par
    printf("=== PART 1: DIGIT SUM STRATEGY ===\\n");\par
    \par
    int roundNumber = 1;\par
    while (!EmptyQueues(&F, &F1, &F3) && TotalMatchesP1 < 3 * numPlayers) \{\par
        printf("\\n--- Round %d ---\\n", roundNumber);\par
        \par
        result = PlayRoundP1(&p1, &p2, &score1, &score2, roundNumber);\par
        DisplayRoundResults(roundNumber, result, &p1, &p2);\par
        ConsecutiveWins(result, &p1, &p2);\par
        SaveGame(&ML, result, roundNumber, &p1, &p2, score1, score2, 1);\par
        PlacePlayersPart1(&F, &F1, &F3, &LG, &LP, result, &p1, &p2);\par
        DisplayQueueStatus(&F, &F1, &F3, roundNumber);\par
        DisplayLists(LG, LP);\par
        \par
        TotalMatchesP1++;\par
        roundNumber++;\par
        \par
        if (result == 1) \{\par
            p2 = SelectNextPlayer(&F, &F1, &F3);\par
        \} else if (result == 2) \{\par
            p1 = SelectNextPlayer(&F, &F1, &F3);\par
        \} else \{\par
            p1 = SelectNextPlayer(&F, &F1, &F3);\par
            p2 = SelectNextPlayer(&F, &F1, &F3);\par
        \}\par
        \par
        if (p1.num == -1 || p2.num == -1) break;\par
    \}\par
\par
    printf("\\n=== PART 1 COMPLETED ===\\n");\par
\par
    // checking if we need to proceed to part 2\par
\par
    if(!EmptyQueues(&F, &F1, &F3) && TotalMatchesP1 >= 3 * numPlayers)\{\par
        printf("\\n=== STRATEGY CHANGE ===\\n");\par
        printf("=== PART 2: GCD STRATEGY ===\\n");\par
        \par
        roundNumber = 1;\par
        while (!EmptyQueues(&F, &F1, &F3) && TotalMatchesP2 < 2 * numPlayers) \{\par
            printf("\\n--- Round %d ---\\n", roundNumber);\par
            \par
            result = PlayRoundP2(&p1, &p2, &score1, &score2, roundNumber);\par
            DisplayRoundResults(roundNumber, result, &p1, &p2);\par
            ConsecutiveWins(result, &p1, &p2);\par
            SaveGame(&ML, result, roundNumber, &p1, &p2, score1, score2, 2);\par
            PlacePlayersPart2(&F, &F1, &F3, &LG, &LP, result, &p1, &p2);\par
            DisplayQueueStatus(&F, &F1, &F3, roundNumber);\par
            DisplayLists(LG, LP);\par
            \par
            TotalMatchesP2++;\par
            roundNumber++;\par
            \par
            p1 = SelectNextPlayer(&F, &F1, &F3);\par
            p2 = SelectNextPlayer(&F, &F1, &F3);\par
            \par
            if (p1.num == -1 || p2.num == -1) break;\par
        \}\par
    \}\par
\par
    if(TotalMatchesP2 >= 2 * numPlayers)\{\par
        printf("\\n=== PART 2 ENDED ===\\n");\par
\par
        // moving remaining players to lists\par
        MoveQueueToList(&F, &LP);\par
        MoveQueueToSortedList(&F1, &LG);\par
        MoveQueueToList(&F3, &LP);\par
    \}\par
\par
    // displaying final winners\par
\par
    printf("\\n=== FINAL RESULTS ===\\n");\par
    DisplayWinners(LG);\par
\par
    printf("\\nGame Over!\\n");\par
\par
    return 0;\par
\}\par

