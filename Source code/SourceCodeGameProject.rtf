int PlayTurnP1(int* nbr, int* sum) \{\par
    // we need to store generated number and its sum to display it later\par
    *nbr = GenerateRandomNbr();\par
    *sum = SumDigits(*nbr);\par
    if (CheckWinCondition(*nbr)) \{\par
        return 1; // Win\par
    \} else \{\par
        return 0; // Lose\par
