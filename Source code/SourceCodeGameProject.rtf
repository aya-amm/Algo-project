// function to insert a player into a list\par
void Insert(element** L, Player p) \{\par
    element* temp;\par
    element* new = (element*)malloc(sizeof(element));\par
    new->info = p;\par
    new->next = NULL;\par
    if (*L == NULL) \{\par
        *L = new;\par
    \} else \{\par
        temp = *L;\par
        while (temp->next != NULL) \{\par
            temp = temp->next;\par
        \}\par
        temp->next = new;\par
    \}\par
\}\par
\par
// function to insert a player into a sorted list based on score \par
void InsertSorted(element** L, Player p) \{\par
    element* new = (element*)malloc(sizeof(element));\par
    new->info = p;\par
    new->next = NULL;\par
\par
    if (*L == NULL || (*L)->info.score <= p.score) \{\par
        new->next = *L;\par
        *L = new;\par
    \} else \{\par
        element* current = *L;\par
        element* previous = NULL;\par
        while (current != NULL && current->info.score >= p.score) \{\par
            previous = current;\par
            current = current->next;\par
        \}\par
        new->next = current;\par
        if(previous != NULL) \{\par
            previous->next = new;\par
        \} else \{\par
            *L = new;\par
        \}\par
    \}\par
\}\par
