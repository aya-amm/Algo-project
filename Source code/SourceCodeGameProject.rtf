// Time functions : \par
void GetCurrentTime(char* timeStr) \{\par
    time_t rawtime;\par
    struct tm* timeinfo;\par
    \par
    time(&rawtime);\par
    timeinfo = localtime(&rawtime);\par
    \par
    sprintf(timeStr, "%02d:%02d:%02d", \par
            timeinfo->tm_hour, \par
            timeinfo->tm_min, \par
            timeinfo->tm_sec);\par
\}\par
\par
int parseTime(const char* timeStr, int* hours, int* minutes, int* seconds) \{\par
    return sscanf(timeStr, "%d:%d:%d", hours, minutes, seconds) == 3;\par
\}\par
\par
void CalculateDuration(const char* startTime, const char* endTime, char* durationStr) \{\par
    int startH, startM, startS;\par
    int endH, endM, endS;\par
    \par
    if (!parseTime(startTime, &startH, &startM, &startS)) \{\par
        strcpy(durationStr, "00:00:00");\par
        return;\par
    \}\par
    \par
    if (!parseTime(endTime, &endH, &endM, &endS)) \{\par
        strcpy(durationStr, "00:00:00");\par
        return;\par
    \}\par
    \par
    int startTotalSeconds = startH * 3600 + startM * 60 + startS;\par
    int endTotalSeconds = endH * 3600 + endM * 60 + endS;\par
    \par
    if (endTotalSeconds < startTotalSeconds) \{\par
        endTotalSeconds += 24 * 3600;\par
    \}\par
    \par
    int totalSeconds = endTotalSeconds - startTotalSeconds;\par
    int hours = totalSeconds / 3600;\par
    totalSeconds %= 3600;\par
    int minutes = totalSeconds / 60;\par
    int seconds = totalSeconds % 60;\par
    \par
    sprintf(durationStr, "%02d:%02d:%02d", hours, minutes, seconds);\par
\}\par
