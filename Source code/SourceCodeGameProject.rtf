// function to select the next player based on queue priorities\par
Player SelectNextPlayer(Queue* F, Queue* F1, Queue* F3) \{\par
    Player p;\par
    \par
    // Priority 1: Queue F1\par
    if(!IsEmpty(F1)) \{\par
        if(F1->head == F1->tail) \{ // Only one player in F1\par
            if(!IsEmpty(F)) \{\par
                Dequeue(F, &p);\par
                return p;\par
            \} else \{\par
                Dequeue(F1, &p);\par
                return p;\par
            \}\par
        \} else \{\par
            Dequeue(F1, &p);\par
            return p;\par
        \}\par
    \}\par
\par
    // Priority 2: Queue F\par
    if (!IsEmpty(F)) \{\par
        if(F->head == F->tail) \{ // Only one player in F\par
            if(!IsEmpty(F3)) \{\par
                Dequeue(F3, &p);\par
                return p;\par
            \} else \{\par
                Dequeue(F, &p);\par
                return p;\par
            \}\par
        \} else \{\par
            Dequeue(F, &p);\par
            return p;\par
        \}\par
    \}\par
\par
    // Priority 3: Queue F3\par
    if(!IsEmpty(F3)) \{\par
        Dequeue(F3, &p);\par
        if(IsEmpty(F3)) \{ // Was the last player\par
            p.losses++;\par
        \}\par
        return p;\par
    \}\par
\par
    // No players available\par
    p.num = -1;\par
    strcpy(p.name, "NO_PLAYER");\par
    return p;\par
\}\par
