        \par
        // Player 1's turn\par
        *score1 += PlayTurnP2(&nbra1, &nbrb1, &g1);\par
        printf("%s's generated numbers: %d, %d, GCD: %d, score: %d\\n", \par
               p1->name, nbra1, nbrb1, g1, *score1);\par
        \par
        if (abs(*score1 - *score2) >= 3) break;\par
        \par
        // Player 2's turn\par
