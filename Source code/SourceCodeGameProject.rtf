// function to compute GCD of two numbers\par
int GCD(int a, int b) \{\par
    while (b != 0) \{\par
        int temp = b;\par
        b = a % b;\par
        a = temp;\par
    \}\par
    return a;\par
\}\par
\par
\par
// checking if a digit is in a number\par
bool DigitInNumber(int digit, int number) \{\par
    while (number > 0) \{\par
        if (number % 10 == digit) \{\par
            return true;\par
        \}\par
        number /= 10;\par
    \}\par
    return false;\par
\}\par
\par
// function to play a turn using the second strategy\par
int PlayTurnP2(int* nbra, int* nbrb, int* g) \{\par
    *nbra = GenerateRandomNbr() % 1000 + 1;\par
    *nbrb = GenerateRandomNbr() % 1000 + 1;\par
    *g = GCD(*nbra, *nbrb);\par
    int temp = *g;\par
    \par
    if (temp == 0) \{\par
        return 0; \par
    \}\par
\par
    do \{\par
        int digit = temp % 10;\par
        if (DigitInNumber(digit, *nbra) || DigitInNumber(digit, *nbrb)) \{\par
            return 1; // Win\par
        \}\par
        temp /= 10;\par
    \} while (temp > 0);\par
    \par
    return 0; // Lose\par
\}\par
