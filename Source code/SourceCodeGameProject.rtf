// function to sum digits of a number\par
int SumDigits(int number) \{\par
    int sum = 0;\par
    while (number > 0) \{\par
        sum += number % 10;\par
        number /= 10;\par
    \}\par
    return sum;\par
\}\par
\par
// function to check win condition of the first strategy\par
bool CheckWinCondition(int number) \{\par
    int sum = SumDigits(number);\par
    return (sum % 5 == 0);\par
\}\par
