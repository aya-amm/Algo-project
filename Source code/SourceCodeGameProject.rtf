// Queue functions\par
void InitQueue(Queue* F) \{\par
    F->head = NULL;\par
    F->tail = NULL;\par
\}\par
\par
void Enqueue(Queue* F, Player p) \{\par
    element* new = (element*)malloc(sizeof(element));\par
    new->info = p;\par
    new->next = NULL;\par
    if (F->tail) \{\par
        F->tail->next = new;\par
    \} else \{\par
        F->head = new;\par
    \}\par
    F->tail = new;\par
\}\par
\par
void Dequeue(Queue* F, Player* p) \{\par
    if (F->head) \{\par
        element* temp = F->head;\par
        *p = temp->info;\par
        F->head = F->head->next;\par
        if (!F->head) \{\par
            F->tail = NULL;\par
        \}\par
        free(temp);\par
    \}\par
\}\par
\par
bool IsEmpty(Queue* F) \{\par
    return F->head == NULL;\par
\}\par
\par
Player HeadQueue(Queue* F) \{\par
    if (F->head) \{\par
        return F->head->info;\par
    \}\par
    Player emptyPlayer = \{0\};\par
    return emptyPlayer;\par
\}\par
\par
Player TailQueue(Queue* F) \{\par
    if (F->tail) \{\par
        return F->tail->info;\par
    \}\par
    Player emptyPlayer = \{0\};\par
    return emptyPlayer;\par
\}\par
